{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "@eveider/mobile#build": {
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@eveider/web-admin#dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "@eveider/web-business#dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
