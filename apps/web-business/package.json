{
  "name": "@eveider/web-business",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "predev": "pnpm --filter @eveider/api-contracts build && pnpm --filter @eveider/domain build && pnpm --filter @eveider/config-ui build && pnpm --filter @eveider/ui build && pnpm --filter @eveider/data-access build",
    "dev": "echo 'Use pnpm --filter @eveider/web-admin dev — unified portal runs on http://localhost:3000' && exit 1",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@eveider/api-contracts": "workspace:*",
    "@eveider/config-ui": "workspace:*",
    "@eveider/data-access": "workspace:*",
    "@eveider/domain": "workspace:*",
    "@eveider/ui": "workspace:*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "nanoid": "3",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eveider/config-eslint": "workspace:*",
    "@eveider/config-typescript": "workspace:*",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
