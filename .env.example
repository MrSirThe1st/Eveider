# Supabase project: clgcdbgnqqiosnijdbns
# Dashboard: https://supabase.com/dashboard/project/clgcdbgnqqiosnijdbns

# Web portal (Next.js) — publishable key (client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://clgcdbgnqqiosnijdbns.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Unified Eveider web portal (landing, login, admin + business dashboards)
# Dev: http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# Mobile (Expo) — same values
EXPO_PUBLIC_SUPABASE_URL=https://clgcdbgnqqiosnijdbns.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only (never expose to client, never commit real values)
SUPABASE_SERVICE_ROLE_KEY=
# Session pooler (recommended for local dev + Prisma) — port 5432, NOT 6543:
DATABASE_URL=postgresql://postgres.clgcdbgnqqiosnijdbns:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
# Optional: Prisma pool size for session pooler (default 10)
# PRISMA_CONNECTION_LIMIT=10
# Transaction pooler (serverless / edge only — causes Prisma pool timeouts in dev):
# DATABASE_URL=postgresql://postgres.clgcdbgnqqiosnijdbns:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Mobile auth API (unified web portal on :3000)
# Simulator: http://localhost:3000
# Physical device: use your machine LAN IP, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_AUTH_API_URL=http://localhost:3000

# Invite links (web landing + deep link base URL)
# Dev web portal: http://localhost:3000
# Dev Expo web: http://localhost:19006
INVITE_WEB_BASE_URL=http://localhost:3000
INVITE_DEEP_LINK_SCHEME=eveider
# Create a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# WhatsApp Cloud API (Meta) — parcel status templates
# Use the TEST phone number ID until the business is verified.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_TEMPLATE_LANGUAGE=fr
WHATSAPP_PARCEL_IN_TRANSIT_TEMPLATE=eveider_parcel_in_transit
WHATSAPP_PARCEL_ARRIVED_TEMPLATE=eveider_parcel_arrived
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# PawaPay sandbox
PAWAPAY_API_TOKEN=
PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_ENV=sandbox
PAWAPAY_DEFAULT_COUNTRY=COD
