{
  "name": "@eveider/data-access",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "dotenv -e ../../.env -- tsx scripts/migrate.ts",
    "db:deploy": "dotenv -e ../../.env -- tsx scripts/migrate.ts",
    "db:seed": "dotenv -e ../../.env -- tsx scripts/seed.ts"
  },
  "dependencies": {
    "@eveider/api-contracts": "workspace:*",
    "@eveider/domain": "workspace:*",
    "@supabase/supabase-js": "^2.49.8",
    "pg": "^8.22.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eveider/config-eslint": "workspace:*",
    "@eveider/config-typescript": "workspace:*",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
