{
  "name": "@eveider/data-access",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@eveider/domain": "workspace:*",
    "@prisma/client": "^6.9.0",
    "@supabase/supabase-js": "^2.49.8",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eveider/config-eslint": "workspace:*",
    "@eveider/config-typescript": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
